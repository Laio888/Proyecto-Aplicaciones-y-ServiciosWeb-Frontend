@page "/registro-calificado"
@rendermode InteractiveServer
@inject RegistroCalificadoService registroService
@inject NavigationManager Navigation

<h3 class="mb-4">Registros Calificados</h3>

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="mb-0 text-muted">Consulta, edición y eliminación de registros calificados.</p>
    <button class="btn btn-primary" @onclick="IrCrear">
        Nuevo Registro
    </button>
</div>

@if (!string.IsNullOrWhiteSpace(mensaje))
{
    <div class="alert alert-info">@mensaje</div>
}

@if (items == null)
{
    <div class="alert alert-secondary">
        Cargando registros...
    </div>
}
else if (!items.Any())
{
    <div class="alert alert-warning">
        No hay registros calificados disponibles.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Código</th>
                    <th>Metodología</th>
                    <th>Créditos</th>
                    <th>Duración</th>
                    <th>Tipo Titulación</th>
                    <th>Programa</th>
                    <th>Vigencia</th>
                    <th style="width: 160px;">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in items)
                {
                    <tr>
                        <td>
                            <span class="fw-bold">@item.Codigo</span>
                        </td>
                        <td>@item.Metodologia</td>
                        <td>@item.CantCreditos</td>
                        <td>
                            @item.DuracionSemestres semestres
                            @if (!string.IsNullOrWhiteSpace(item.DuracionAnios))
                            {
                                <div class="text-muted small">@item.DuracionAnios años</div>
                            }
                        </td>
                        <td>@item.TipoTitulacion</td>
                        <td>@item.Programa</td>
                        <td>
                            <div>@item.FechaInicio.ToString("dd/MM/yyyy")</div>
                            <div class="text-muted small">hasta @item.FechaFin.ToString("dd/MM/yyyy")</div>
                        </td>
                        <td>
                            <button class="btn btn-warning btn-sm me-2"
                                    @onclick="() => IrEditar(item.Codigo)">
                                Editar
                            </button>

                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => Eliminar(item.Codigo)">
                                Eliminar
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@code {
    private List<RegistroCalificado>? items;
    private string mensaje = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await Cargar();
    }

    private async Task Cargar()
    {
        try
        {
            mensaje = string.Empty;
            items = await registroService.GetAll();
        }
        catch (Exception ex)
        {
            mensaje = $"Error: {ex.Message}";
            items = new List<RegistroCalificado>();
        }
    }

    private void IrCrear()
    {
        Navigation.NavigateTo("/registro-calificado/create");
    }

    private void IrEditar(int codigo)
    {
        Navigation.NavigateTo($"/registro-calificado/edit/{codigo}");
    }

    private async Task Eliminar(int codigo)
    {
        try
        {
            var ok = await registroService.Delete(codigo);

            if (ok)
            {
                await Cargar();
                mensaje = "Eliminado correctamente.";
            }
            else
            {
                mensaje = "No se pudo eliminar el registro.";
            }
        }
        catch (Exception ex)
        {
            mensaje = $"Error: {ex.Message}";
        }
    }
}