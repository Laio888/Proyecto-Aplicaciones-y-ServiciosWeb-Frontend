@page "/pasantias"
@rendermode InteractiveServer

@using FrontendBlazor_Aplicaciones_y_Servicios_Web.Modelos
@inject PasantiaService pasantiaService
@inject ProgramaService programaService

<h3>Pasantías</h3>

<a href="/pasantias/create">Crear nueva</a>

@if (pasantias == null || programas == null)
{
    <p>Cargando...</p>
}
else if (!pasantias.Any())
{
    <p>No hay registros.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>País</th>
                <th>Empresa</th>
                <th>Programa</th>
                <th>Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var p in pasantias)
            {
                var prog = programas.FirstOrDefault(x => x.Id == p.Programa);

                <tr>
                    <td>@p.Id</td>
                    <td>@p.Nombre</td>
                    <td>@p.Pais</td>
                    <td>@p.Empresa</td>
                    <td>@(prog?.Nombre ?? "No encontrado")</td>

                    <td>
                        <a href="/pasantias/edit/@p.Id">Editar</a>
                        <button @onclick="() => Eliminar(p.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Pasantia> pasantias = new();
    private List<Programa> programas = new();

    protected override async Task OnInitializedAsync()
    {
        pasantias = await pasantiaService.GetAll();
        programas = await programaService.GetAll();
    }

    private async Task Eliminar(int id)
    {
        await pasantiaService.Delete(id);
        pasantias.RemoveAll(x => x.Id == id);
    }
}