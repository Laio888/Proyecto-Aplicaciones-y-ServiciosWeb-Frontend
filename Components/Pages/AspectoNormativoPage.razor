@page "/aspectos"
@rendermode InteractiveServer
@using FrontendBlazor_Aplicaciones_y_Servicios_Web.Modelos
@inject FrontendBlazor_Aplicaciones_y_Servicios_Web.Services.AspectoNormativoService aspectoService

<h3>Aspectos Normativos</h3>

@if (aspectos == null)
{
    <p>Cargando...</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>ID</th>
                <th>Tipo</th>
                <th>Descripción</th>
                <th>Fuente</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in aspectos)
            {
                <tr>
                    <td>@a.Id</td>
                    <td>@a.Tipo</td>
                    <td>@a.Descripcion</td>
                    <td>@a.Fuente</td>
                    <td>
                        <button class="btn btn-warning btn-sm me-2" @onclick="() => Editar(a)">Editar</button>
                        <button class="btn btn-danger btn-sm" @onclick="() => Eliminar(a.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <h4>@(editando ? "Editar aspecto" : "Crear nuevo aspecto")</h4>

    @if (!string.IsNullOrWhiteSpace(mensaje))
    {
        <div class="alert alert-info">@mensaje</div>
    }

    <div class="form-group">
        <input class="form-control mb-2" placeholder="Tipo" @bind="nuevo.Tipo" />
        <input class="form-control mb-2" placeholder="Descripción" @bind="nuevo.Descripcion" />
        <input class="form-control mb-2" placeholder="Fuente" @bind="nuevo.Fuente" />

        @if (editando)
        {
            <button class="btn btn-success me-2" @onclick="GuardarEdicion">Actualizar</button>
            <button class="btn btn-secondary" @onclick="CancelarEdicion">Cancelar</button>
        }
        else
        {
            <button class="btn btn-primary" @onclick="Crear">Guardar</button>
        }
    </div>
}

@code {
    private List<AspectoNormativo>? aspectos;
    private AspectoNormativo nuevo = new AspectoNormativo();
    private bool editando = false;
    private int idEditando = 0;
    private string mensaje = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        aspectos = await aspectoService.GetAll();
    }

    private async Task Crear()
    {
        mensaje = string.Empty;

        var ok = await aspectoService.Create(nuevo);
        if (ok)
        {
            aspectos = await aspectoService.GetAll();
            nuevo = new AspectoNormativo();
            mensaje = "Registro creado correctamente.";
        }
        else
        {
            mensaje = "No se pudo crear el registro.";
        }
    }

    private void Editar(AspectoNormativo aspecto)
    {
        nuevo = new AspectoNormativo
        {
            Id = aspecto.Id,
            Tipo = aspecto.Tipo,
            Descripcion = aspecto.Descripcion,
            Fuente = aspecto.Fuente
        };

        idEditando = aspecto.Id;
        editando = true;
        mensaje = $"Editando registro {aspecto.Id}";
    }

    private async Task GuardarEdicion()
    {
        mensaje = string.Empty;

        var ok = await aspectoService.Update(idEditando, nuevo);
        if (ok)
        {
            aspectos = await aspectoService.GetAll();
            nuevo = new AspectoNormativo();
            editando = false;
            idEditando = 0;
            mensaje = "Registro actualizado correctamente.";
        }
        else
        {
            mensaje = "No se pudo actualizar el registro.";
        }
    }

    private async Task Eliminar(int id)
    {
        mensaje = string.Empty;

        var ok = await aspectoService.Delete(id);
        if (ok)
        {
            aspectos = await aspectoService.GetAll();
            mensaje = "Registro eliminado correctamente.";
        }
        else
        {
            mensaje = $"No se pudo eliminar el registro con id {id}.";
        }
    }

    private void CancelarEdicion()
    {
        nuevo = new AspectoNormativo();
        editando = false;
        idEditando = 0;
        mensaje = "Edición cancelada.";
    }
}