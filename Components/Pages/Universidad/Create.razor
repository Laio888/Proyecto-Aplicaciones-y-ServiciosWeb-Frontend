@page "/universidades/create"
@rendermode InteractiveServer

@using Microsoft.AspNetCore.Components.Forms
@using FrontendBlazor_Aplicaciones_y_Servicios_Web.Modelos

@inject UniversidadService universidadService
@inject NavigationManager nav

<h3>Crear Universidad</h3>

<EditForm Model="universidad" OnValidSubmit="Guardar">
    <InputText @bind-Value="universidad.Nombre" placeholder="Nombre" />
    <InputText @bind-Value="universidad.Tipo" placeholder="Tipo" />
    <InputText @bind-Value="universidad.Ciudad" placeholder="Ciudad" />

    <button type="submit">Guardar</button>
</EditForm>

@code {
    private Universidad universidad = new();

    private async Task Guardar()
    {
        await universidadService.Create(universidad);
        nav.NavigateTo("/universidades");
    }
}