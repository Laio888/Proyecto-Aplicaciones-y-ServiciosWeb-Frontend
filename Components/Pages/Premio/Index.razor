@page "/premios"
@rendermode InteractiveServer

@using FrontendBlazor_Aplicaciones_y_Servicios_Web.Modelos
@inject PremioService premioService
@inject ProgramaService programaService

<h3>Premios</h3>

<a href="/premios/create">Crear nuevo</a>

@if (premios == null || programas == null)
{
    <p>Cargando...</p>
}
else if (!premios.Any())
{
    <p>No hay registros.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Nombre</th>
                <th>Descripción</th>
                <th>Fecha</th>
                <th>Entidad Otorgante</th>
                <th>País</th>
                <th>Programa</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in premios)
            {
                var prog = programas.FirstOrDefault(x => x.Id == p.Programa);
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Nombre</td>
                    <td>@p.Descripcion</td>
                    <td>@p.Fecha</td>
                    <td>@p.EntidadOtorgante</td>
                    <td>@p.Pais</td>
                    <td>@(prog?.Nombre ?? "No encontrado")</td>
                    <td>
                        <a href="/premios/edit/@p.Id">Editar</a>
                        <button @onclick="() => Eliminar(p.Id)">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<Premio> premios = new();
    private List<Programa> programas = new();

    protected override async Task OnInitializedAsync()
    {
        premios = await premioService.GetAll();
        programas = await programaService.GetAll();
    }

    private async Task Eliminar(int id)
    {
        await premioService.Delete(id);
        premios.RemoveAll(p => p.Id == id);
    }
}